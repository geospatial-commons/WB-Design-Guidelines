{
  "_source": "WBG Digital Look & Feel Style Guide V2 + conflict-app DESIGN.md",
  "dashboard": {
    "_comment": "Core tokens for UI components in WB dashboards",
    "wb-blue":    { "hex": "#009FDA", "rgb": [0, 159, 218],   "usage": "Primary action, links, active states, chart lines, left-border accents" },
    "wb-navy":    { "hex": "#002244", "rgb": [0, 34, 68],     "usage": "Sidebar, page headers, feature KPI cards, section anchors" },
    "wb-teal":    { "hex": "#00A996", "rgb": [0, 169, 150],   "usage": "Positive indicators, success states, secondary accent" },
    "wb-white":   { "hex": "#FFFFFF", "rgb": [255, 255, 255], "usage": "Page background, card backgrounds" },
    "wb-gray-50":  { "hex": "#F7F8FA", "rgb": [247, 248, 250], "usage": "App shell background" },
    "wb-gray-100": { "hex": "#EEF0F3", "rgb": [238, 240, 243], "usage": "Dividers, table zebra rows" },
    "wb-gray-500": { "hex": "#6B7280", "rgb": [107, 114, 128], "usage": "Secondary text, labels, metadata" },
    "wb-gray-900": { "hex": "#111827", "rgb": [17, 24, 39],    "usage": "Primary body text" }
  },
  "status": {
